# Copie para .env e ajuste se necessário.
# Windows CMD: copy .env.example .env
# PowerShell: Copy-Item .env.example .env

# PostgreSQL — instância deste projeto (docker-compose: roboauto_postgres, porta host 5436)
DATABASE_URL="postgresql://roboauto:roboauto123@localhost:5436/roboauto"

# Redis — instância deste projeto (roboauto_redis, porta host 6380)
REDIS_URL="redis://:roboauto_redis@localhost:6380"

PORT=3001
NODE_ENV=development
# Uma origem ou várias (CORS / Socket.IO), separadas por vírgula — útil na Render (preview + prod).
FRONTEND_URL=http://localhost:5173

# Desenvolvimento — troque em produção
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
ENCRYPTION_KEY=dev-encryption-key-change-in-production

BULLEX_PLATFORM_ID=580

# Primeiro super admin (só na primeira subida, se ainda não existir ADMIN).
# Ou: node scripts/create-initial-admin.mjs
# INITIAL_ADMIN_EMAIL=admin@exemplo.com
# INITIAL_ADMIN_PASSWORD=troque_por_senha_forte
# INITIAL_ADMIN_NAME=Super Admin
